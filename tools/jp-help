}

function command(signature, description, examples, filters) {
    console.log(c.green + "  " + signature + c.reset);
    console.log("    " + description);
    if (examples && examples.length) {
        console.log(c.gray + "    exemplos:" + c.reset);
        examples.forEach((example) => console.log("      " + colorExample(example)));
    }
    if (filters) {
        console.log(c.gray + "    filtros avancados:" + c.reset);
        filters.forEach((line) => console.log("      " + line));
    }
    console.log("");
}

function colorText(color, value) {
    return color + value + c.reset;
}

function commandText(value) {
    return colorText(c.green, value);
}

function optionText(value) {
    return colorText(c.cyan, value);
}

function filterText(value) {
    return colorText(c.yellow, value);
}

function operatorText(value) {
    return colorText(c.magenta, value);
}

function isNumberToken(token) {
    return /^-?\d+(?:[,.]\d+)?$/.test(String(token || ""));
}

function isPosterSizeToken(token) {
    return /^(?:16x9|9x16|1x1|square|msk|dsk)$/i.test(token) || /^\d+x\d+$/i.test(token);
}

function isCaptureModeToken(token) {
    return /^(?:msk|dsk|mobile|desktop)$/i.test(token);
}

function globalOptionKind(commandName, token) {
    if (commandName === "jp-capture") {
        if (isCaptureModeToken(token)) return "format";
        if (isNumberToken(token)) return "wait";
    }

    if (commandName === "jp-poster") {
        if (isPosterSizeToken(token)) return "size";
        if (isNumberToken(token)) return "seconds";
    }

    if (commandName === "jp-compress") {
        if (isNumberToken(token)) return "quality";
    }

    return "";
}

function globalOptionKey(kind, token) {
    const value = isNumberToken(token)
        ? String(Number(String(token).replace(",", ".")))
        : String(token || "").toLowerCase();
    return kind + ":" + value;
}

function colorExample(example) {
    const tokens = String(example || "").trim().split(/\s+/).filter(Boolean);
    if (!tokens.length) return "";

    const commandName = tokens[0];
    const seenOptions = new Set();
    let filterStarted = false;
    let afterAnd = false;

    return tokens.map((token, index) => {
        const lowerToken = token.toLowerCase();

        if (index === 0) return commandText(token);

        if (lowerToken === "--and" || lowerToken === "--not") {
            afterAnd = lowerToken === "--and";
            if (lowerToken === "--not") filterStarted = true;
            return operatorText(token);
        }

        const optionKind = globalOptionKind(commandName, token);
        const optionKey = optionKind ? globalOptionKey(optionKind, token) : "";

        if (optionKind && (!filterStarted || afterAnd)) {
            seenOptions.add(optionKey);
            return optionText(token);
        }

        filterStarted = true;
        afterAnd = false;
        return filterText(token);
    }).join(" ");
}

function walkDirs(dir, results = []) {
    let entries;

    try {
        entries = fs.readdirSync(dir, { withFileTypes: true });
    } catch (error) {
        return results;
    }

    for (const entry of entries) {
        if (!entry.isDirectory()) continue;
        if (ignoredDirs.has(entry.name)) continue;
        if (entry.name.startsWith(".")) continue;

        const fullPath = path.join(dir, entry.name);
        results.push(fullPath);
        walkDirs(fullPath, results);
    }

    return results;
}

function walkFiles(dir, results = []) {
    let entries;

    try {
        entries = fs.readdirSync(dir, { withFileTypes: true });
    } catch (error) {
        return results;
    }

    for (const entry of entries) {
        if (entry.isDirectory()) {
            if (ignoredDirs.has(entry.name)) continue;
            if (entry.name.startsWith(".")) continue;
            walkFiles(path.join(dir, entry.name), results);
            continue;
        }

        if (entry.isFile()) results.push(path.join(dir, entry.name));
    }

    return results;
}

function rel(filePath) {
    return path.relative(root, filePath).split(path.sep).join("/");
}

function firstDifferent(items, first) {
    return items.find((item) => item !== first) || first;
}

function captureModeForScope(scope) {
    const parts = String(scope || "").split(/[\\/]/).map((part) => part.toLowerCase());
    return parts.includes("dsk") || parts.includes("desktop") ? "dsk" : "msk";
}

function findIndexFiles() {
    return searchRoots.flatMap((searchRoot) => walkFiles(searchRoot))
        .filter((filePath) => path.basename(filePath).toLowerCase() === "index.html")
        .sort();
}

function findAssetsDirs() {
    return searchRoots.flatMap((searchRoot) => [searchRoot, ...walkDirs(searchRoot)]).filter((dir) => {
        if (path.basename(dir).toLowerCase() !== "assets") return false;
        return path.basename(path.dirname(dir)).toLowerCase() === "banner" || rel(dir).split("/").includes("banner");
    }).sort();
}

function collectVideoHtmlEntries() {
    return searchRoots.flatMap((searchRoot) => walkFiles(searchRoot))
        .filter((filePath) => /\.html?$/i.test(filePath))
        .filter((filePath) => {
            try {
                return /\.(?:mp4|webm|mov|m4v)(?:[?"'\s<]|$)/i.test(fs.readFileSync(filePath, "utf8"));
            } catch (error) {
                return false;
            }
        })
        .sort()
        .map((filePath) => ({
            name: path.basename(filePath),
            path: rel(filePath)
        }));
}

function scopeFromIndex(indexPath) {
    const scope = rel(path.dirname(indexPath));
    return scope || "";
}

function scopeFromAssets(assetsDir) {
    const bannerDir = path.dirname(assetsDir);
    const scope = rel(path.dirname(bannerDir));
    return scope || "";
}

function collectScopes() {
    const scopes = new Set();

    findIndexFiles().forEach((indexPath) => {
        const scope = scopeFromIndex(indexPath);
        if (scope) scopes.add(scope);
    });

    findAssetsDirs().forEach((assetsDir) => {
        const scope = scopeFromAssets(assetsDir);
        if (scope) scopes.add(scope);
    });

    return Array.from(scopes).sort((a, b) => a.localeCompare(b));
}

function collectImagePairs() {
    const pairs = [];

    findAssetsDirs().forEach((assetsDir) => {
        const scope = scopeFromAssets(assetsDir);
        if (!scope) return;

        const images = walkFiles(assetsDir)
            .filter((filePath) => imageExts.has(path.extname(filePath).toLowerCase()))
            .filter((filePath) => !path.basename(filePath).startsWith(".jp-compress-"))
            .sort((a, b) => a.localeCompare(b));

        if (images.length) {
            pairs.push({ scope, image: path.basename(images[0]) });
        }
    });

    return pairs.sort((a, b) => a.scope.localeCompare(b.scope));
}

function buildExamples() {
    const scopes = collectScopes();
    const first = scopes[0] || "EN/V1";
    const second = firstDifferent(scopes, first) || "FR/Product_Test";
    const third = scopes.find((scope) => scope !== first && scope !== second) || "";
    const pairs = collectImagePairs();
    const firstPair = pairs[0] || { scope: first, image: "CTA.png" };
    const secondPair = pairs.find((pair) => pair.scope !== firstPair.scope || pair.image !== firstPair.image) || { scope: second, image: "chat-2.png" };
    const videoHtmlEntries = collectVideoHtmlEntries();
    const firstVideoHtml = videoHtmlEntries[0] || { name: "expanded_video.html", path: first + "/banner/expanded_video.html" };
    const secondVideoHtml = videoHtmlEntries.find((item) => item.name !== firstVideoHtml.name) || { name: "left.html", path: second + "/banner/left.html" };
    const firstVideoHtmlCount = videoHtmlEntries.filter((item) => item.name === firstVideoHtml.name).length || 1;
    const firstCaptureMode = captureModeForScope(first);

    return {
        hasDetected: scopes.length > 0 || pairs.length > 0 || videoHtmlEntries.length > 0,
        scope1: first,
        scope2: second,
        scope3: third,
        htmlName1: firstVideoHtml.name,
        htmlPath1: firstVideoHtml.path,
        htmlCount1: firstVideoHtmlCount,
        htmlName2: secondVideoHtml.name,
        capture: [
            "jp-capture",
            "jp-capture " + firstCaptureMode + " 3 " + first,
            "jp-capture " + firstCaptureMode + " 10 " + first,
            third ? "jp-capture " + first + " --and " + second + " --not " + third : (second !== first ? "jp-capture " + first + " --not " + second : "jp-capture " + first)
        ],
        captureRemove: [
            "jp-capture-remove",
            second !== first ? "jp-capture-remove " + first + " --and " + second : "jp-capture-remove " + first,
            second !== first ? "jp-capture-remove " + first + " --not " + second : "jp-capture-remove " + first
        ],
        poster: [
            "jp-poster",
            "jp-poster 5 " + firstVideoHtml.name,
            "jp-poster 5 " + firstVideoHtml.name + " --and 20 " + secondVideoHtml.name,
            "jp-poster 5 " + firstVideoHtml.path,
            second !== first ? "jp-poster 16x9 5 " + first + " --and 2 " + second : "jp-poster 16x9 5 " + first
        ],
        posterRemove: [
            "jp-poster-remove",
            second !== first ? "jp-poster-remove " + first + " --and " + second : "jp-poster-remove " + first,
            second !== first ? "jp-poster-remove " + first + " --not " + second : "jp-poster-remove " + first
        ],
        compress: [
            "jp-compress 80",
            second !== first ? "jp-compress 80 " + first + " --and 70 " + second : "jp-compress 80 " + first,
            firstPair ? "jp-compress 80 " + firstPair.scope + " " + firstPair.image : "jp-compress 80 " + first + " CTA.png",
            secondPair && secondPair.scope !== firstPair.scope ? "jp-compress 80 " + firstPair.scope + " " + firstPair.image + " --and " + secondPair.scope + " " + secondPair.image : "jp-compress 80 " + firstPair.scope + " " + firstPair.image
        ],
        compressOriginal: [
            "jp-compress-original",
            firstPair ? "jp-compress-original " + firstPair.scope + " --not " + firstPair.image : "jp-compress-original " + first + " --not CTA.png",
            secondPair && secondPair.scope !== firstPair.scope ? "jp-compress-original " + firstPair.scope + " --not " + firstPair.image + " --and " + secondPair.scope + " --not " + secondPair.image : "jp-compress-original " + first
        ],
        compressOriginalRemove: [
            "jp-compress-original-remove",
            second !== first ? "jp-compress-original-remove " + first + " --and " + second : "jp-compress-original-remove " + first,
            second !== first ? "jp-compress-original-remove " + first + " --not " + second : "jp-compress-original-remove " + first
        ],
        detected: [
            "jp-capture " + firstCaptureMode + " 3 " + first,
            second !== first ? "jp-capture " + first + " --and " + second : "jp-capture " + first,
            videoHtmlEntries.length ? "jp-poster 5 " + firstVideoHtml.name : "jp-poster 16x9 5 " + first,
            firstPair ? "jp-compress 80 " + firstPair.scope + " " + firstPair.image : "jp-compress 80 " + first + " CTA.png"
        ]
    };
}

